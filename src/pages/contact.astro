---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact Pluzi – Start your website project"
  description="Tell Pluzi about your website project. Share your goals, business details and examples so we can respond with ideas, structure and next steps – all via email."
>
  <Header />

  <main class="section">
    <div class="container contact-page">
      <div class="contact-page-intro">
        <h1 class="contact-heading">Start your website project with Pluzi</h1>
        <p class="contact-text">
          Share a few details about your business and what you'd like from your website.
          You'll get a reply by email from Sonny with ideas, questions and a suggested next step.
        </p>
        <p class="contact-meta">
          Prefer to write your own email? You can always reach us directly at
          <br />
          <strong>sonnywebsites@gmail.com</strong>.
        </p>
      </div>

      <div class="contact-page-form-shell">
        <form
          id="contact-form"
          class="contact-form"
          method="post"
          action="/__forms/contact"
          novalidate
        >
          <input type="text" name="_hp" style="display:none" tabindex="-1" />

          <div class="form-group">
            <label for="contact-name">
              Your name <span aria-label="required">*</span>
            </label>
            <input
              id="contact-name"
              name="name"
              type="text"
              required
              aria-required="true"
              aria-describedby="contact-name-error"
              autocomplete="name"
            />
            <span id="contact-name-error" class="form-error" role="alert"></span>
          </div>

          <div class="form-group">
            <label for="contact-email">
              Email address <span aria-label="required">*</span>
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              required
              aria-required="true"
              aria-describedby="contact-email-error"
              autocomplete="email"
            />
            <span id="contact-email-error" class="form-error" role="alert"></span>
          </div>

          <div class="form-group">
            <label for="contact-message">
              Tell us about your project <span aria-label="required">*</span>
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              required
              aria-required="true"
              aria-describedby="contact-message-error"
              placeholder="Your business, the goal of the website, example sites you like, rough timeline…"
            ></textarea>
            <span id="contact-message-error" class="form-error" role="alert"></span>
          </div>

          <div id="contact-response" class="form-response" role="alert" aria-live="polite"></div>

          <button type="submit" class="btn btn-primary full-width">
            Send details and start by email
          </button>

          <p class="contact-note">
            Sonny usually replies within minutes (up to 1 hour).
          </p>
        </form>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
