---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Pluzi – Email landing"
  description="Share your email with Sonny so he can get back to you about your website project."
>
  <Header />

  <section id="hero" class="section hero hero-brief">
    <div class="container hero-layout">
      <div>
        <div class="hero-kicker">
          <span class="hero-kicker-pill">Done‑for‑you</span>
          Start your website project with a quick email handoff.
        </div>
        <h1 class="hero-title">
          Share your email,<br />
          <span class="hero-highlight">Sonny will get back to you</span>.
        </h1>
        <p class="hero-subtitle">
          Pluzi designs, builds and launches your website through simple email conversations.
          No builders, no dashboards, no calls – just clear, done‑for‑you implementation handled
          directly over email with Sonny.
        </p>

        <div class="hero-meta-row">
          <div class="hero-meta-pill">
            <span class="hero-meta-dot"></span>
            Direct, 1‑on‑1 with Sonny
          </div>
          <div class="hero-meta-pill">Everything handled over email</div>
          <div class="hero-meta-pill">No builders, no dashboards, no calls</div>
        </div>
      </div>

      <aside class="hero-right-shell hero-brief-form-shell">
        <form
          id="email-landing-form"
          class="contact-form"
          method="post"
          action="/__forms/contact"
          novalidate
        >
          <input type="hidden" name="sourceSlug" value="email-landing" />
          <div class="form-group form-group-inline">
            <label for="email-landing-email">Your email</label>
            <input
              id="email-landing-email"
              name="email"
              type="email"
              required
              aria-required="true"
              placeholder="you@example.com"
              autocomplete="email"
            />
          </div>
          <input type="text" name="_hp" style="display:none" tabindex="-1" autocomplete="off" />
          <button type="submit" class="btn btn-primary full-width">
            Send
          </button>
          <div
            id="email-landing-response"
            class="form-response"
            role="alert"
            aria-live="polite"
          ></div>
        </form>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container strip">
      <div>
        <div class="eyebrow">Pluzi is a fit if…</div>
        <p class="muted">
          you’d rather send a few emails than learn new tools. Tell us how you’d like your
          site to look and what it should do – we turn it into a polished, live website.
        </p>
      </div>
      <div class="strip-logos">
        <div class="logo-pill">
          <span class="logo-dot"></span>
          New website from scratch
        </div>
        <div class="logo-pill">
          <span class="logo-dot"></span>
          Redesign &amp; relaunch
        </div>
        <div class="logo-pill">
          <span class="logo-dot"></span>
          Landing pages for campaigns
        </div>
      </div>
    </div>
  </section>

  <section id="services" class="section section-muted">
    <div class="container">
      <div class="section-header">
        <div class="section-title">
          <span class="section-title-dot"></span>
          Process
        </div>
        <h2 class="section-heading">How a project with Pluzi works.</h2>
        <p class="section-subtitle">
          Everything runs through email – transparent, easy to follow and at your pace.
          You don’t need any extra tools, dashboards or logins.
        </p>
      </div>

      <div class="services-grid">
        <article class="service-card">
          <div class="service-tag">Step 1</div>
          <h3 class="service-title">Email your ideas and context</h3>
          <p class="service-text">
            Send a message to <a href="mailto:sonnywebsites@gmail.com">sonnywebsites@gmail.com</a>
            with a short description of your business, goals and example sites you like.
          </p>
          <div class="service-meta">No forms, no account – just a normal email.</div>
        </article>

        <article class="service-card">
          <div class="service-tag">Step 2</div>
          <h3 class="service-title">Structure, design &amp; content proposal</h3>
          <p class="service-text">
            Sonny proposes the site structure, page layout and design direction – all
            written out clearly in your inbox so you can review and reply.
          </p>
          <div class="service-meta">You give feedback directly in the email thread.</div>
        </article>

        <article class="service-card">
          <div class="service-tag">Step 3</div>
          <h3 class="service-title">Build, refinements &amp; launch</h3>
          <p class="service-text">
            The website is built, refined and polished with you until it feels right.
            Pluzi then handles launch and technical setup so it goes live smoothly.
          </p>
          <div class="service-meta">You hit “Go” by email – the site goes live.</div>
        </article>
      </div>
    </div>
  </section>

  <section id="benefits" class="section">
    <div class="container">
      <div class="section-header center">
        <div class="section-title">
          <span class="section-title-dot"></span>
          Why Pluzi?
        </div>
        <h2 class="section-heading">Less hassle for you, more focus on your work.</h2>
        <p class="section-subtitle">
          Pluzi is built for solo founders and small teams who want a professional website
          without learning tools, wrangling builders or sitting in calls.
        </p>
      </div>

      <div class="features-grid">
        <div class="feature-item">
          <div class="feature-icon">✓</div>
          <div>
            <div class="feature-title">Everything handled over email</div>
            <div class="feature-text">
              Instead of new tools or ticketing systems, you simply reply to emails.
              No complicated platforms or interfaces – every decision and change
              is written down in one clear place.
            </div>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">✓</div>
          <div>
            <div class="feature-title">Personal, direct with Sonny</div>
            <div class="feature-text">
              No rotating team, no call center – one person handles planning, design,
              implementation and changes for your site.
            </div>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">✓</div>
          <div>
            <div class="feature-title">Professional implementation</div>
            <div class="feature-text">
              Fast, modern sites with a clear structure – ideal if you want
              to look credible and be easy to understand.
            </div>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">✓</div>
          <div>
            <div class="feature-title">Clear process instead of chaos</div>
            <div class="feature-text">
              From first idea to launch we follow a simple process so nothing
              gets lost on the way.
            </div>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">✓</div>
          <div>
            <div class="feature-title">Easy to request changes</div>
            <div class="feature-text">
              Want new copy, another section or fresher images? Send a quick email,
              Pluzi takes care of it.
            </div>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">✓</div>
          <div>
            <div class="feature-title">No builder lock‑in</div>
            <div class="feature-text">
              Instead of getting stuck in a rigid page builder, we focus on a
              clean implementation that can grow with you later.
            </div>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">✓</div>
          <div>
            <div class="feature-title">No complicated platforms or interfaces</div>
            <div class="feature-text">
              You never have to log into a builder, CMS or dashboard – everything is
              coordinated in simple email threads while the implementation is handled for you.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="projects" class="section section-muted">
    <div class="container">
      <div class="section-header">
        <div class="section-title">
          <span class="section-title-dot"></span>
          Projects
        </div>
        <h2 class="section-heading">Examples of projects Pluzi can deliver.</h2>
        <p class="section-subtitle">
          Every site is tailored – structure, copy and design are planned around your business.
          These are common patterns Pluzi can implement for you.
        </p>
      </div>

      <div class="projects-grid">
        <article class="project-card">
          <div class="project-pill">
            <span>Local business</span>
          </div>
          <h3 class="project-title">Service website with clear contact flow</h3>
          <p class="project-text">
            Home, services, about and contact – structured so visitors can understand
            what you do and reach out in just a few clicks.
          </p>
          <div class="project-meta">Great for coaches, consultants, studios and local services.</div>
        </article>

        <article class="project-card">
          <div class="project-pill">
            <span>Landing page</span>
          </div>
          <h3 class="project-title">Campaign page for a specific offer</h3>
          <p class="project-text">
            A focused page with a simple story, proof and a clear call‑to‑action –
            ideal for ads, launches or limited‑time offers.
          </p>
          <div class="project-meta">Useful for new products, promos or events.</div>
        </article>

        <article class="project-card">
          <div class="project-pill">
            <span>Relaunch</span>
          </div>
          <h3 class="project-title">Fresh look for an existing site</h3>
          <p class="project-text">
            Keep your content, modernise the look: clearer structure, sharper copy,
            mobile‑friendly and technically cleaned up.
          </p>
          <div class="project-meta">Perfect if your current site is “okay” but no longer on‑brand.</div>
        </article>
      </div>
    </div>
  </section>

  <section id="pricing" class="section">
    <div class="container">
      <div class="section-header center">
        <h2 class="section-heading">Everything is 100% free.</h2>
        <p class="section-subtitle">
          Pluzi plans, designs, builds and launches your website completely free of charge.
          No setup fees, no subscriptions, no hidden costs – just send an email to get started.
        </p>
      </div>

      <div class="pricing-grid">
        <article class="pricing-card">
          <div class="pricing-badge">Included</div>
          <div class="pricing-label">Launch‑ready landing page</div>
          <div class="pricing-note">Perfect for a single offer, campaign or idea you want online fast.</div>
          <ul class="pricing-list">
            <li>
              <span class="pricing-dot">•</span>
              <span>1 focused page with a simple story &amp; clear contact CTA</span>
            </li>
            <li>
              <span class="pricing-dot">•</span>
              <span>Structure, layout &amp; copy agreed with you over email – no builders to learn</span>
            </li>
            <li>
              <span class="pricing-dot">•</span>
              <span>Mobile‑friendly, performance‑conscious build handled entirely for you</span>
            </li>
          </ul>
          <a href="mailto:sonnywebsites@gmail.com?subject=Landing%20page%20with%20Pluzi" class="btn btn-secondary">
            Ask about a free landing page
          </a>
        </article>

        <article class="pricing-card">
          <div class="pricing-badge">Included</div>
          <div class="pricing-label">Small website</div>
          <div class="pricing-note">Ideal for solo founders &amp; small businesses – still 100% free.</div>
          <ul class="pricing-list">
            <li>
              <span class="pricing-dot">•</span>
              <span>Up to 3–5 pages (for example: Home, Services, About, Contact)</span>
            </li>
            <li>
              <span class="pricing-dot">•</span>
              <span>Design matched to your brand and audience with no complicated platforms involved</span>
            </li>
            <li>
              <span class="pricing-dot">•</span>
              <span>Revisions &amp; polish via email included – no extra tools or interfaces</span>
            </li>
          </ul>
          <a href="mailto:sonnywebsites@gmail.com?subject=Website%20project%20with%20Pluzi" class="btn btn-primary">
            Discuss your free website by email
          </a>
        </article>

        <article class="pricing-card">
          <div class="pricing-badge">Included</div>
          <div class="pricing-label">Larger or custom project</div>
          <div class="pricing-note">For bigger sites or special requirements – still free to start.</div>
          <ul class="pricing-list">
            <li>
              <span class="pricing-dot">•</span>
              <span>More pages, special features or complex content as needed</span>
            </li>
            <li>
              <span class="pricing-dot">•</span>
              <span>Deeper planning directly with Sonny via email, no project portal logins</span>
            </li>
            <li>
              <span class="pricing-dot">•</span>
              <span>No complicated pricing tables – everything is discussed plainly over email</span>
            </li>
          </ul>
          <a
            href="mailto:sonnywebsites@gmail.com?subject=Custom%20website%20project%20with%20Pluzi"
            class="btn btn-secondary"
          >
            Talk about a free custom project
          </a>
        </article>
      </div>
    </div>
  </section>

  <section id="contact" class="section">
    <div class="container">
      <div class="contact-shell">
        <div>
          <h2 class="contact-heading">Prefer to start with a direct email?</h2>
          <p class="contact-text">
            You can also email Pluzi directly with a few bullet points about your project.
          </p>
          <p class="contact-meta">
            Email <strong>sonnywebsites@gmail.com</strong> – Sonny will reply personally.
          </p>
        </div>
        <div class="contact-actions">
          <a
            href="mailto:sonnywebsites@gmail.com?subject=Website%20project%20with%20Pluzi"
            class="btn btn-primary"
          >
            Email Sonny about your project
          </a>
          <span class="contact-pill">Replies usually within minutes (up to 1 hour)</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

