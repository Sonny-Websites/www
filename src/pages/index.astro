---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const mailtoHref =
  'mailto:sonnywebsites@gmail.com?subject=Website%20Project%20Inquiry&body=Hi%20Sonny%2C%20I%20am%20interested%20in%20building%20a%20website%20with%20Pluzi.%20Here%20are%20my%20details%3A%20%5BPlease%20provide%20your%20requirements%20here%5D';
---

<BaseLayout title="Pluzi - Website Building Service" description="Get your professional website built effortlessly via email with Pluzi.">
  <Header />

  <section id="hero">
    <h2>Welcome to Pluzi</h2>
    <p>Get your professional website built effortlessly through email communication.</p>
    <a href={mailtoHref} class="cta-button">Start Your Project</a>
  </section>

  <section id="how-it-works">
    <h2>How It Works</h2>
    <div class="steps">
      <div class="step">
        <h3>1. Contact Sonny</h3>
        <p>
          Send an email to
          <a href={mailtoHref}>sonnywebsites@gmail.com</a>
          with your website requirements.
        </p>
      </div>
      <div class="step">
        <h3>2. Discuss Details</h3>
        <p>Sonny will communicate with you via email to understand your vision and needs.</p>
      </div>
      <div class="step">
        <h3>3. Build &amp; Edit</h3>
        <p>Sonny creates your website and makes all edits directly through email exchanges.</p>
      </div>
      <div class="step">
        <h3>4. Launch</h3>
        <p>Once complete, your website is ready to go live!</p>
      </div>
    </div>
  </section>

  <section id="benefits">
    <h2>Why Choose Pluzi?</h2>
    <ul>
      <li>
        <strong>Convenient:</strong>
        No meetings or complex tools needed.
      </li>
      <li>
        <strong>Direct Communication:</strong>
        All interactions via email.
      </li>
      <li>
        <strong>Expert Service:</strong>
        Sonny handles everything professionally.
      </li>
      <li>
        <strong>Flexible:</strong>
        Easy to request changes and updates.
      </li>
    </ul>
  </section>

  <section id="contact">
    <h2>Get Started Today</h2>
    <p>Ready to build your website? Reach out to Sonny now!</p>
    <a href={mailtoHref} class="cta-button">Email Sonny</a>
  </section>

  <Footer />
</BaseLayout>

